<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@color/surface_card"
    android:animateLayoutChanges="true">

    <!-- ────────────────────────────────────────────────────
         Row: dot + event description + timestamp
         ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layout_row_summary"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Coloured dot (BREACH=red, APPROACH=amber, RESOLVED=green) -->
        <View
            android:id="@+id/view_dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_alert_dot"
            android:contentDescription="@string/cd_status_pill" />

        <!-- Event description -->
        <TextView
            android:id="@+id/tv_event_description"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Hardware timestamp (tap to switch to server timestamp) -->
        <TextView
            android:id="@+id/tv_timestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textSize="12sp"
            android:textStyle="italic"
            android:textColor="@color/text_disabled"
            android:minWidth="48dp"
            android:gravity="end" />

    </LinearLayout>

    <!-- ────────────────────────────────────────────────────
         Expandable detail section (GONE by default)
         ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layout_expanded_detail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:paddingTop="8dp"
        android:visibility="gone">

        <!-- Thin divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="8dp" />

        <!-- Sensor grid — 2 columns -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_detail_hum_inlet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:text="Hum In: —" />

                <TextView
                    android:id="@+id/tv_detail_temp_inlet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:text="Temp In: —"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tv_detail_moisture_5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:text="Soil 5 cm: —"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_detail_hum_outlet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:text="Hum Out: —" />

                <TextView
                    android:id="@+id/tv_detail_temp_outlet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:text="Temp Out: —"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tv_detail_moisture_10"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:text="Soil 10 cm: —"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Actuator state line -->
        <TextView
            android:id="@+id/tv_detail_actuators"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="6dp"
            android:text="Pump: OFF | Fan: OFF" />

    </LinearLayout>

</LinearLayout>
