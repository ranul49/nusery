<?xml version="1.0" encoding="utf-8"?>
<!-- Sensor card background with coloured stroke border.
     Stroke colour is set programmatically based on sensor state. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="12dp" />
    <solid android:color="@color/surface_card" />
    <stroke android:width="1.5dp" android:color="#00000000" /> <!-- transparent by default -->
</shape>
