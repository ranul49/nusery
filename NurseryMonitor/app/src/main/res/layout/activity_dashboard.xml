<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark"
    tools:context=".ui.dashboard.DashboardActivity">

    <!-- ════════════════════════════════════════════════════════════════════
         Main scrollable content
         ════════════════════════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_dashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ────────────────────────────────────────────────────────────
                 App header row
                 ──────────────────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:fontFamily="@font/roboto" />

                    <TextView
                        android:id="@+id/tv_last_updated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textStyle="italic"
                        android:textColor="@color/text_disabled"
                        android:text="Connecting…" />

                </LinearLayout>

                <!-- BLE signal indicator (GONE when online) -->
                <LinearLayout
                    android:id="@+id/layout_ble_signal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_ble_bars"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/status_approach"
                        android:contentDescription="@string/cd_ble_signal"
                        android:text="▂▄▆" />

                </LinearLayout>

            </LinearLayout>

            <!-- ────────────────────────────────────────────────────────────
                 BLE offline banner (GONE when online)
                 ──────────────────────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/banner_ble_offline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_ble_banner"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/ble_banner_title"
                    android:textSize="13sp"
                    android:textColor="@color/status_approach" />

                <TextView
                    android:id="@+id/tv_ble_cached_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textStyle="italic"
                    android:textColor="@color/text_disabled" />

            </LinearLayout>

            <!-- ════════════════════════════════════════════════════════════
                 TRAFFIC-LIGHT STATUS PILL — dominant element, full-width
                 ════════════════════════════════════════════════════════════ -->
            <TextView
                android:id="@+id/tv_status_pill"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:gravity="center"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/roboto"
                android:background="@drawable/bg_status_pill"
                android:elevation="4dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_status_pill"
                android:text="@string/status_nominal"
                android:layout_marginBottom="12dp"
                tools:backgroundTint="@color/status_nominal" />

            <!-- ════════════════════════════════════════════════════════════
                 ACTIVE ACTUATION BANNER (GONE by default; shown on BREACH)
                 ════════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/banner_actuation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_actuation_banner"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_actuation_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/status_breach"
                    android:textStyle="bold"
                    tools:text="Misting pump ON since 14:32 — humidity recovering" />

            </LinearLayout>

            <!-- ════════════════════════════════════════════════════════════
                 SENSOR CARDS CONTAINER (collapsible — GONE by default)
                 Tapping the status pill toggles visibility.
                 ════════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/layout_sensor_cards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:animateLayoutChanges="true">

                <!-- Section heading -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sensor Readings"
                    android:textSize="18sp"
                    android:fontFamily="@font/roboto_medium"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <!-- ── DHT22 Inlet Card ────────────────────────────────── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_dht_inlet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/card_dht_inlet"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:id="@+id/tv_dht_inlet_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textColor="@color/status_nominal"
                                android:text="@string/label_ok" />

                        </LinearLayout>

                        <!-- Humidity row -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_humidity"
                            android:textSize="12sp"
                            android:textColor="@color/text_disabled"
                            android:layout_marginTop="10dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="2dp">

                            <ProgressBar
                                android:id="@+id/progress_hum_inlet"
                                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                                android:layout_width="0dp"
                                android:layout_height="8dp"
                                android:layout_weight="1"
                                android:max="100"
                                android:progress="85"
                                android:progressTint="@color/status_nominal" />

                            <TextView
                                android:id="@+id/tv_hum_inlet_value"
                                android:layout_width="56dp"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textColor="@color/text_primary"
                                android:gravity="end"
                                android:text="—" />

                        </LinearLayout>

                        <!-- Temperature row -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_temperature"
                            android:textSize="12sp"
                            android:textColor="@color/text_disabled"
                            android:layout_marginTop="8dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="2dp">

                            <ProgressBar
                                android:id="@+id/progress_temp_inlet"
                                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                                android:layout_width="0dp"
                                android:layout_height="8dp"
                                android:layout_weight="1"
                                android:max="50"
                                android:progress="28"
                                android:progressTint="@color/status_nominal" />

                            <TextView
                                android:id="@+id/tv_temp_inlet_value"
                                android:layout_width="56dp"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textColor="@color/text_primary"
                                android:gravity="end"
                                android:text="—" />

                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── DHT22 Outlet Card ───────────────────────────────── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_dht_outlet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/card_dht_outlet"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:id="@+id/tv_dht_outlet_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textColor="@color/status_nominal"
                                android:text="@string/label_ok" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_humidity"
                            android:textSize="12sp"
                            android:textColor="@color/text_disabled"
                            android:layout_marginTop="10dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="2dp">

                            <ProgressBar
                                android:id="@+id/progress_hum_outlet"
                                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                                android:layout_width="0dp"
                                android:layout_height="8dp"
                                android:layout_weight="1"
                                android:max="100"
                                android:progress="85"
                                android:progressTint="@color/status_nominal" />

                            <TextView
                                android:id="@+id/tv_hum_outlet_value"
                                android:layout_width="56dp"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textColor="@color/text_primary"
                                android:gravity="end"
                                android:text="—" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_temperature"
                            android:textSize="12sp"
                            android:textColor="@color/text_disabled"
                            android:layout_marginTop="8dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="2dp">

                            <ProgressBar
                                android:id="@+id/progress_temp_outlet"
                                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                                android:layout_width="0dp"
                                android:layout_height="8dp"
                                android:layout_weight="1"
                                android:max="50"
                                android:progress="28"
                                android:progressTint="@color/status_nominal" />

                            <TextView
                                android:id="@+id/tv_temp_outlet_value"
                                android:layout_width="56dp"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textColor="@color/text_primary"
                                android:gravity="end"
                                android:text="—" />

                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── Soil Probe 5 cm Card ───────────────────────────── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_soil_5cm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/card_soil_5cm"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:id="@+id/tv_soil5_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textColor="@color/status_nominal"
                                android:text="@string/label_ok" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="10dp">

                            <ProgressBar
                                android:id="@+id/progress_soil_5cm"
                                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                                android:layout_width="0dp"
                                android:layout_height="8dp"
                                android:layout_weight="1"
                                android:max="100"
                                android:progress="70"
                                android:progressTint="@color/status_nominal" />

                            <TextView
                                android:id="@+id/tv_soil5_value"
                                android:layout_width="64dp"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textColor="@color/text_primary"
                                android:gravity="end"
                                android:text="—" />

                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── Soil Probe 10 cm Card ──────────────────────────── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_soil_10cm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/card_soil_10cm"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:id="@+id/tv_soil10_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textColor="@color/status_nominal"
                                android:text="@string/label_ok" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="10dp">

                            <ProgressBar
                                android:id="@+id/progress_soil_10cm"
                                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                                android:layout_width="0dp"
                                android:layout_height="8dp"
                                android:layout_weight="1"
                                android:max="100"
                                android:progress="70"
                                android:progressTint="@color/status_nominal" />

                            <TextView
                                android:id="@+id/tv_soil10_value"
                                android:layout_width="64dp"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textColor="@color/text_primary"
                                android:gravity="end"
                                android:text="—" />

                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
            <!-- end sensor cards -->

            <!-- ════════════════════════════════════════════════════════════
                 ACTUATOR TOGGLES
                 ════════════════════════════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manual Actuator Control"
                android:textSize="18sp"
                android:fontFamily="@font/roboto_medium"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Pump toggle row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Misting Pump  (Ch 1)"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_pump"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:contentDescription="@string/cd_pump_toggle"
                            android:checked="false" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider" />

                    <!-- Fan toggle row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="0dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Cooling Fan  (Ch 2)"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_fan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:contentDescription="@string/cd_fan_toggle"
                            android:checked="false" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ════════════════════════════════════════════════════════════
                 ALERT LOG — reverse-chronological, last 50 events
                 ════════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/alert_log_title"
                    android:textSize="18sp"
                    android:fontFamily="@font/roboto_medium"
                    android:textColor="@color/text_primary" />

                <!-- Loading spinner shown during poll -->
                <ProgressBar
                    android:id="@+id/progress_poll"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:indeterminate="true"
                    android:visibility="invisible" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_alert_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                tools:itemCount="5"
                tools:listitem="@layout/item_alert_log" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ════════════════════════════════════════════════════════════════════
         Bottom Navigation Bar
         ════════════════════════════════════════════════════════════════════ -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/nav_background"
        app:itemIconTint="@color/nav_item_tint"
        app:itemTextColor="@color/nav_item_tint"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"
        app:selectedItemId="@id/nav_home" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
